# OpenWeatherMap API Key
# Get your free API key at: https://openweathermap.org/api
VITE_OPENWEATHERMAP_API_KEY=your_api_key_here

# Windy Webcams API Key (Optional - for automatic webcam discovery)
# Get your free API key at: https://api.windy.com/keys
# Without this key, you'll still see search suggestions for finding webcams manually
VITE_WINDY_API_KEY=
