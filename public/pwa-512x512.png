<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512">
  <defs>
    <linearGradient id="bg" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#7dd3fc"/>
      <stop offset="100%" stop-color="#0369a1"/>
    </linearGradient>
    <radialGradient id="sunFill" cx="45%" cy="40%" r="60%">
      <stop offset="0%" stop-color="#fff9c4"/>
      <stop offset="50%" stop-color="#fcd34d"/>
      <stop offset="100%" stop-color="#f59e0b"/>
    </radialGradient>
    <radialGradient id="lensFill" cx="35%" cy="30%" r="70%">
      <stop offset="0%" stop-color="#60a5fa"/>
      <stop offset="60%" stop-color="#1d4ed8"/>
      <stop offset="100%" stop-color="#0f172a"/>
    </radialGradient>
  </defs>
  <!-- Background -->
  <rect width="512" height="512" rx="108" fill="url(#bg)"/>
  <!-- Sun soft halo -->
  <circle cx="256" cy="200" r="160" fill="#fbbf24" opacity="0.18"/>
  <!-- 8 sun rays -->
  <g transform="translate(256,200)" fill="#fde68a">
    <rect x="-11" y="-178" width="22" height="52" rx="11"/>
    <rect x="-11" y="-178" width="22" height="52" rx="11" transform="rotate(45)"/>
    <rect x="-11" y="-178" width="22" height="52" rx="11" transform="rotate(90)"/>
    <rect x="-11" y="-178" width="22" height="52" rx="11" transform="rotate(135)"/>
    <rect x="-11" y="-178" width="22" height="52" rx="11" transform="rotate(180)"/>
    <rect x="-11" y="-178" width="22" height="52" rx="11" transform="rotate(225)"/>
    <rect x="-11" y="-178" width="22" height="52" rx="11" transform="rotate(270)"/>
    <rect x="-11" y="-178" width="22" height="52" rx="11" transform="rotate(315)"/>
  </g>
  <!-- Sun circle -->
  <circle cx="256" cy="200" r="108" fill="url(#sunFill)"/>
  <!-- Camera body -->
  <rect x="138" y="285" width="236" height="150" rx="22" fill="#1e293b"/>
  <!-- Viewfinder bump -->
  <rect x="206" y="262" width="100" height="30" rx="10" fill="#1e293b"/>
  <!-- Lens outer ring -->
  <circle cx="256" cy="358" r="58" fill="#0f172a"/>
  <!-- Lens chrome ring -->
  <circle cx="256" cy="358" r="50" fill="#475569"/>
  <!-- Lens glass -->
  <circle cx="256" cy="358" r="42" fill="url(#lensFill)"/>
  <!-- Lens reflection -->
  <ellipse cx="244" cy="346" rx="13" ry="9" fill="white" opacity="0.28" transform="rotate(-30,244,346)"/>
  <circle cx="270" cy="370" r="5" fill="white" opacity="0.12"/>
  <!-- Record light -->
  <circle cx="332" cy="308" r="13" fill="#ef4444" opacity="0.3"/>
  <circle cx="332" cy="308" r="9" fill="#ef4444"/>
  <defs>
    <linearGradient id="grad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#3b82f6;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#2563eb;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="512" height="512" rx="128" fill="url(#grad)"/>
  <path d="M256 130L230 185L282 185L256 130Z M256 225L200 310H312L256 225Z" fill="white" opacity="0.9"/>
  <circle cx="256" cy="382" r="54" fill="white" opacity="0.9"/>
  <path d="M160 320Q160 265 215 265T270 320" stroke="white" stroke-width="10" fill="none" opacity="0.7"/>
  <path d="M245 320Q245 265 300 265T355 320" stroke="white" stroke-width="10" fill="none" opacity="0.7"/>
</svg>
